@model IEnumerable<GiuaKyNetCore_Nhom6.Models.Member>

@{
    ViewData["Title"] = "Giới thiệu nhóm";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 text-primary fw-bold">CHÀO MỪNG ĐẾN VỚI @ViewBag.GroupName</h1>
        <p class="lead">Hệ thống Quản lý Thư viện - ASP.NET Core 9.0 MVC</p>
        <hr class="w-25 mx-auto">
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h3 class="mb-0">Danh Sách Thành Viên</h3>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">MSSV</th>
                                <th>Họ và Tên</th>
                                <th>Nhiệm vụ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-secondary">@item.StudentId</td>
                                    <td>@item.Name</td>
                                    <td><span class="badge bg-info text-dark">@item.Role</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer text-center bg-light text-muted italic py-3">
                    Đồ án môn học: Lập trình Web nâng cao
                </div>
            </div>
        </div>
    </div>
</div>