@model GiuaKyNetCore_Nhom6.Models.Phieumuonsach

@{
    ViewData["Title"] = "Chi Tiết Phiếu Mượn";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <h4>Mã phiếu: <span class="badge badge-info border border-primary text-dark p-2">PM00@(Model.MaPhieuMuon)</span></h4>
        </div>
        <div class="col-md-6 text-right">
            <h4>Ngày mượn: <span class="border p-2">@Model.NgayMuon.ToString("dd/MM/yyyy")</span></h4>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <h4>Người mượn: <span class="border p-2 d-inline-block w-75">@(Model.MaDocGiaNavigation?.HoTenDocGia ?? "N/A")</span></h4>
        </div>
    </div>

    <table class="table table-bordered text-center">
        <thead class="thead-light">
            <tr>
                <th>Mã</th>
                <th>Tên HH (Sách)</th>
                <th>Hình</th>
                <th>NXB</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var chitiet in Model.Chitietphieumuons)
            {
                <tr>
                    <td class="text-danger font-weight-bold">@chitiet.MaSach</td>
                    <td>@chitiet.MaSachNavigation.TenSach</td>
                    <td>
                        @if (!string.IsNullOrEmpty(chitiet.MaSachNavigation.AnhBia))
                        {
                            <img src="~/images/@chitiet.MaSachNavigation.AnhBia" alt="Ảnh bìa" style="max-height: 80px;" />
                        }
                        else
                        {
                            <span>Không có hình</span>
                        }
                    </td>
                    <td>@chitiet.MaSachNavigation.MaNxbNavigation?.TenNxb</td>
                </tr>
            }
        </tbody>
    </table>
</div>